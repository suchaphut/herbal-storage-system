# ──────────────────────────────────────────────────────────────────────────────
# IoT Herbal Storage Monitoring System — Environment Variables
# Copy this file to .env.local and fill in the values.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Required ─────────────────────────────────────────────────────────────────

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/herbal_storage

# JWT secret key (เปลี่ยนค่านี้เสมอก่อน deploy production!)
JWT_SECRET=change-me-to-a-strong-random-secret

# API key สำหรับ ESP32/IoT sensors ส่งข้อมูลเข้า POST /api/data/ingest
SENSOR_API_KEY=your-sensor-api-key-here

# ─── Optional: Python ML ──────────────────────────────────────────────────────
# ดูรายละเอียดเพิ่มเติมที่ docs/README_ML.md

# เปิดใช้ Prophet + scikit-learn Isolation Forest แทนโมเดล TypeScript
# ENABLE_PYTHON_ML=1

# เปิดใช้ Ensemble Anomaly Detection (IF + LSTM Autoencoder + One-Class SVM)
# USE_ENSEMBLE_ANOMALY=1

# Path คำสั่ง Python ถ้าไม่ใช้ python / python3 ใน PATH (เช่น Windows venv)
# PYTHON_PATH=python

# TTL ของ ML prediction cache (มิลลิวินาที, default: 300000 = 5 นาที)
# ML_CACHE_TTL_MS=300000

# ─── Optional: Cron / Scheduled Tasks ─────────────────────────────────────────

# Secret for Vercel Cron jobs (auto-generated by Vercel, or set manually)
# ใช้สำหรับ /api/sensors/check-offline ที่ทำงานทุก 5 นาที
# CRON_SECRET=your-cron-secret-here

# ─── Optional: Notifications ──────────────────────────────────────────────────

# Discord Webhook URL (global fallback สำหรับทุกห้อง)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# LINE Notify Access Token (global fallback สำหรับทุกห้อง)
# LINE_NOTIFY_TOKEN=your-line-notify-token

# ─── Optional: External Weather Integration ───────────────────────────────────

# OpenWeatherMap API Key สำหรับดึงข้อมูลอากาศภายนอก
# ลงทะเบียนฟรีที่: https://openweathermap.org/api
# OPENWEATHER_API_KEY=your-openweathermap-api-key
